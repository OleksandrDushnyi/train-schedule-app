generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum TrainType {
  EXPRESS
  REGIONAL
  SUBURBAN
  INTERCITY
}

model Station {
  id        String      @id @default(uuid())
  name      String
  code      String?     @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  routeStops RouteStop[]

  @@index([name])
}

model Route {
  id          String          @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  stops       RouteStop[]
  schedules   TrainSchedule[]
  favorites   FavoriteRoute[]

  @@index([name])
}

model RouteStop {
  id               String   @id @default(uuid())
  routeId          String
  route            Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  stationId        String
  station          Station  @relation(fields: [stationId], references: [id], onDelete: Restrict)
  sequence         Int
  minutesFromStart Int      @default(0)

  @@unique([routeId, sequence])
  @@index([routeId])
}

model TrainSchedule {
  id           String    @id @default(uuid())
  routeId      String
  route        Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  departureAt  DateTime
  trainNumber  String
  trainType    TrainType
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([routeId, departureAt])
  @@index([departureAt])
  @@index([trainType])
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  passwordHash  String
  role          Role            @default(USER)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  refreshTokens RefreshToken[]
  favoriteRoutes FavoriteRoute[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jti       String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model FavoriteRoute {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  routeId   String
  route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, routeId])
  @@index([userId])
  @@index([routeId])
}
